# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Local development (MongoDB Community Server)
MONGODB_URI=mongodb://localhost:27017/eduflow

# OR MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eduflow?retryWrites=true&w=majority

# ─── Auth (future — NextAuth.js or custom JWT) ───────────────────────────────
NEXTAUTH_SECRET=replace_with_a_random_32_char_string
NEXTAUTH_URL=http://localhost:3000

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google Maps (Transport tracking — optional) ─────────────────────────────
# Used by the live route map on the Driver / Admin / Management transport pages.
# Without a key the map falls back to a built-in schematic route view.
# Restrict the key to HTTP referrers + the Maps JavaScript API in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
